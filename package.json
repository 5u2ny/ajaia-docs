    "@tiptap/react": "^2.8.0",
    "@tiptap/starter-kit": "^2.8.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.453.0",
