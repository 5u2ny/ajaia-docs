# Copy this file to .env and fill in values for local dev.
#
# Every environment (dev + prod) talks to Postgres. For dev you can either
# point at a local Postgres, a Docker container, or a Neon dev branch.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Optional: direct (non-pooled) connection used by `prisma migrate`. If you
# are on Neon, copy the "Direct connection" string here; otherwise leave
# blank and migrations will reuse DATABASE_URL.
DIRECT_URL=""

# 32+ char random string used to sign session JWTs.
# Generate one with: openssl rand -hex 32
SESSION_SECRET="replace-me-with-a-real-32-char-secret-string"

NODE_ENV="development"
